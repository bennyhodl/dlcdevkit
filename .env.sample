ESPLORA_TIMEOUT_SECONDS=5

BITCOIND_USER=dlcdevkit
BITCOIND_PASS=dlcdevkit
BITCOIND_HOST=http://localhost:18443
ZMQ_BLOCKHASH_ENDPOINT=tcp://localhost:28334
RPC_WALLET=ddk
